@model POS.Application.DTOs.CategoryDto
@{
    ViewData["Title"] = "Update Category";
}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="mb-0">Edit Category</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <!-- Name -->
                        <div class="col-12">
                            <label asp-for="Name" class="form-label fw-semibold"></label>
                            <input asp-for="Name"
                                   class="form-control @(ViewData.ModelState["Name"]?.Errors.Count > 0 ? "is-invalid" : "")"
                                   placeholder="Enter category name">
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <!-- Description -->
                        <div class="col-12">
                            <label asp-for="Description" class="form-label fw-semibold"></label>
                            <textarea asp-for="Description" class="form-control"
                                      rows="3" placeholder="Optional description"></textarea>
                        </div>

                        <!-- Categories (multi-select) -->
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Categories</label>
                            <select name="ParentCategoryId" class="form-select">
                                <option value="@Model.ParentCategoryId">@Model.ParentCategoryId</option>
                                @foreach (var cat in ViewBag.Categories as IEnumerable<POS.Application.DTOs.CategoryDto>)
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            </select>
                            <small class="text-muted">Hold Ctrl to select multiple</small>
                        </div>

                        <!-- Image -->
                        <div class="col-12">
                            <label class="form-label fw-semibold">Product Image</label>
                            <input type="file" name="imageFile"
                                   class="form-control" accept="image/*">
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary px-4">
                            Create Category
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
