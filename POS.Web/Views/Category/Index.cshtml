@model IEnumerable<POS.Application.DTOs.CategoryDto>
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "All Categories";
}
@if (TempData["success"] !=null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>
        @TempData["success"]
        <button type="button" class="btn-close"
                data-bs-dismiss="alert"></button>
    </div>
}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="d-flex card-header justify-content-between align-items-center mb-3">
                <h5 class="mb-0">All Categories</h5>
                <a asp-action="Create" asp-controller="Category" class="btn btn-success btn-sm">+ Create New Category</a>
            </div>
        
        <table class="table">
            <thead>
                <tr>
                    <th scope="col">#</th>
                    <th scope="col">Id</th>
                    <th scope="col">Name</th>
                    <th scope="col">Parent</th>
                    <th scope="col">Description</th>
                    <th scope="col">Action</th>
                </tr>
            </thead>
            <tbody>
                    @{
                        int i = 1;
                    }
                @foreach (var item in Model)
                {
                    <tr>
                        <th scope="row">@i</th>
                        <td>@item.Id</td>
                        <td>@item.Name</td>
                        <td>@item.ParentCategoryId</td>
                        <td>@item.Description</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm py-0 px-1" style="font-size: 0.75rem;">Edit</a>
                                <form asp-action="Delete"
                                      asp-route-id="@item.Id"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm(
                                    'Delete @item.Name? ' +
                                    'This cannot be undone.')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn btn-danger btn-sm py-0 px-1" style="font-size: 0.75rem;">
                                        Delete
                                    </button>
                                </form>
                                
                    </tr>
                        i++;
                    }

        
            </tbody>
        </table>
        </div>
    </div>
</div>

