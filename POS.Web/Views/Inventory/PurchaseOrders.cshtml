<!-- POS.Web/Views/Inventory/PurchaseOrders.cshtml -->
@model IEnumerable<POS.Application.DTOs.PurchaseOrderDto>
@{
    ViewData["Title"] = "Purchase Orders";
    Layout = "_Layout";
}

@if (TempData["success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle-fill me-2"></i>
        @TempData["success"]
        <button type="button" class="btn-close"
                data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-x-circle-fill me-2"></i>
        @TempData["error"]
        <button type="button" class="btn-close"
                data-bs-dismiss="alert"></button>
    </div>
}

<!-- ── Page header ────────────────────────────────────────────────── -->
<div class="d-flex justify-content-between
    align-items-center mb-4">
    <div>
        <h4 class="mb-1">Purchase Orders</h4>
        <p class="text-muted small mb-0">
            Manage supplier purchases and stock receiving
        </p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Suppliers"
           class="btn btn-outline-secondary">
            <i class="bi bi-people me-1"></i>Suppliers
        </a>
        <a asp-action="CreatePurchaseOrder"
           class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>New Purchase Order
        </a>
    </div>
</div>

<!-- ── Summary cards ─────────────────────────────────────────────── -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 bg-primary bg-opacity-10">
            <div class="card-body">
                <div class="d-flex justify-content-between
                    align-items-center">
                    <div>
                        <div class="text-muted small">Total Orders</div>
                        <div class="fs-4 fw-bold text-primary">
                            @Model.Count()
                        </div>
                    </div>
                    <i class="bi bi-cart-plus fs-2 text-primary
                    opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 bg-warning bg-opacity-10">
            <div class="card-body">
                <div class="d-flex justify-content-between
                    align-items-center">
                    <div>
                        <div class="text-muted small">Pending</div>
                        <div class="fs-4 fw-bold text-warning">
                            @Model.Count(o =>
                                o.Status ==
                                POS.Domain.Enums.PurchaseStatus.Pending)
                        </div>
                    </div>
                    <i class="bi bi-hourglass-split fs-2 text-warning
                    opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 bg-success bg-opacity-10">
            <div class="card-body">
                <div class="d-flex justify-content-between
                    align-items-center">
                    <div>
                        <div class="text-muted small">Received</div>
                        <div class="fs-4 fw-bold text-success">
                            @Model.Count(o =>
                                o.Status ==
                                POS.Domain.Enums.PurchaseStatus.Received)
                        </div>
                    </div>
                    <i class="bi bi-check-circle fs-2 text-success
                    opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 bg-info bg-opacity-10">
            <div class="card-body">
                <div class="d-flex justify-content-between
                    align-items-center">
                    <div>
                        <div class="text-muted small">Total Value</div>
                        <div class="fs-4 fw-bold text-info">
                            $@Model.Sum(o => o.TotalAmount)
                            .ToString("N2")
                        </div>
                    </div>
                    <i class="bi bi-currency-dollar fs-2 text-info
                    opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── Filter bar ─────────────────────────────────────────────────── -->
<div class="card shadow-sm mb-4">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-semibold">
                    Status
                </label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">All Statuses</option>
                    <option value="0">Pending</option>
                    <option value="1">Received</option>
                    <option value="2">Partially Received</option>
                    <option value="3">Cancelled</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">
                    From Date
                </label>
                <input type="date"
                       name="from"
                       class="form-control form-control-sm">
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">
                    To Date
                </label>
                <input type="date"
                       name="to"
                       class="form-control form-control-sm">
            </div>
            <div class="col-md-3">
                <button type="submit"
                        class="btn btn-outline-secondary btn-sm w-100">
                    <i class="bi bi-funnel me-1"></i>Filter
                </button>
            </div>
        </form>
    </div>
</div>

<!-- ── Purchase orders table ─────────────────────────────────────── -->
<div class="card shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox fs-1 opacity-25 d-block mb-3"></i>
                <p class="fw-semibold mb-1">No purchase orders yet</p>
                <small>Create your first purchase order to get started</small>
                <div class="mt-3">
                    <a asp-action="CreatePurchaseOrder"
                       class="btn btn-primary btn-sm">
                        <i class="bi bi-plus-lg me-1"></i>
                        Create Purchase Order
                    </a>
                </div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">PO Number</th>
                            <th>Supplier</th>
                            <th>Order Date</th>
                            <th>Items</th>
                            <th class="text-end">Total Amount</th>
                            <th class="text-center">Status</th>
                            <th class="text-center pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var po in Model)
                        {
                            <tr>
                                <!-- PO Number -->
                                <td class="ps-3">
                                    <div class="fw-semibold font-monospace
                                        text-primary">
                                        @po.PurchaseOrderNumber
                                    </div>
                                    <small class="text-muted">
                                        ID: @po.Id
                                    </small>
                                </td>

                                <!-- Supplier -->
                                <td>
                                    <div class="d-flex align-items-center
                                        gap-2">
                                        <div class="avatar-sm bg-secondary
                                            bg-opacity-10 rounded-circle
                                            d-flex align-items-center
                                            justify-content-center">
                                            <i class="bi bi-building
                                            text-secondary"></i>
                                        </div>
                                        <span class="fw-semibold">
                                            @po.SupplierName
                                        </span>
                                    </div>
                                </td>

                                <!-- Order Date -->
                                <td>
                                    <div>
                                        @po.OrderDate.ToString("dd MMM yyyy")
                                    </div>
                                    <small class="text-muted">
                                        @po.OrderDate.ToString("HH:mm")
                                    </small>
                                </td>

                                <!-- Items count -->
                                <td>
                                    <span class="badge bg-secondary
                                        bg-opacity-10
                                        text-secondary
                                        rounded-pill">
                                        @po.Items.Count item@(po.Items.Count != 1 ? "s" : "")
                                    </span>
                                </td>

                                <!-- Total -->
                                <td class="text-end fw-bold">
                                    $@po.TotalAmount.ToString("N2")
                                </td>

                                <!-- Status badge -->
                                <td class="text-center">
                                    @{
                                        var statusClass = po.Status switch
                                        {
                                            POS.Domain.Enums.PurchaseStatus
                                                .Pending => "bg-warning text-dark",
                                            POS.Domain.Enums.PurchaseStatus
                                                .Received => "bg-success",
                                            POS.Domain.Enums.PurchaseStatus
                                                .PartiallyReceived => "bg-info text-dark",
                                            POS.Domain.Enums.PurchaseStatus
                                                .Cancelled => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                        var statusIcon = po.Status switch
                                        {
                                            POS.Domain.Enums.PurchaseStatus
                                                .Pending => "bi-hourglass-split",
                                            POS.Domain.Enums.PurchaseStatus
                                                .Received => "bi-check-circle-fill",
                                            POS.Domain.Enums.PurchaseStatus
                                                .PartiallyReceived => "bi-arrow-repeat",
                                            POS.Domain.Enums.PurchaseStatus
                                                .Cancelled => "bi-x-circle-fill",
                                            _ => "bi-question-circle"
                                        };
                                    }
                                    <span class="badge @statusClass">
                                        <i class="bi @statusIcon me-1"></i>
                                        @po.Status
                                    </span>
                                </td>

                                <!-- Actions -->
                                <td class="text-center pe-3">
                                    <div class="d-flex justify-content-center
                                        gap-1">

                                        <!-- View details -->
                                        <button type="button"
                                                class="btn btn-sm
                                            btn-outline-primary"
                                                data-bs-toggle="modal"
                                                data-bs-target="#poDetailModal"
                                                onclick="loadPoDetail(@po.Id)"
                                                title="View Details">
                                            <i class="bi bi-eye"></i>
                                        </button>

                                        <!-- Receive stock -->
                                        @if (po.Status ==
                                             POS.Domain.Enums
                                                 .PurchaseStatus.Pending ||
                                             po.Status ==
                                             POS.Domain.Enums
                                                 .PurchaseStatus.PartiallyReceived)
                                        {
                                            <form asp-action="ReceivePurchaseOrder"
                                                  asp-route-id="@po.Id"
                                                  method="post"
                                                  class="d-inline"
                                                  onsubmit="return confirm(
                                                'Receive PO @po.PurchaseOrderNumber? ' +
                                                'Stock will be added for all items.')">
                                                @Html.AntiForgeryToken()
                                                <button type="submit"
                                                        class="btn btn-sm
                                                    btn-outline-success"
                                                        title="Receive Stock">
                                                    <i class="bi bi-box-arrow-in-down"></i>
                                                </button>
                                            </form>
                                        }

                                        <!-- Print PO -->
                                        <a href="/Inventory/PrintPO/@po.Id"
                                           target="_blank"
                                           class="btn btn-sm
                                            btn-outline-secondary"
                                           title="Print">
                                            <i class="bi bi-printer"></i>
                                        </a>

                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════════
     PO DETAIL MODAL
══════════════════════════════════════════════════════════════════════ -->
<div class="modal fade"
     id="poDetailModal"
     tabindex="-1"
     aria-labelledby="poDetailModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold"
                    id="poDetailModalLabel">
                    <i class="bi bi-file-text me-2"></i>
                    Purchase Order Details
                </h5>
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="poDetailBody">
                <div class="text-center py-4">
                    <div class="spinner-border text-primary"></div>
                    <p class="mt-2 text-muted">Loading details...</p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Close
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function loadPoDetail(id) {
            const body = document.getElementById('poDetailBody');
            body.innerHTML = `
                <div class="text-center py-4">
                    <div class="spinner-border text-primary"></div>
                    <p class="mt-2 text-muted">Loading details...</p>
                </div>`;

            try {
                const res  = await fetch(`/Inventory/PurchaseOrderDetail/${id}`);
                const html = await res.text();
                body.innerHTML = html;
            } catch (e) {
                body.innerHTML = `
                    <div class="alert alert-danger">
                        Failed to load details. Please try again.
                    </div>`;
            }
        }
    </script>
}