<!-- POS.Web/Views/Inventory/_PurchaseOrderDetail.cshtml -->
@model POS.Application.DTOs.PurchaseOrderDto

<div class="row g-3 mb-3">
    <div class="col-md-6">
        <table class="table table-borderless table-sm mb-0">
            <tr>
                <td class="text-muted fw-semibold"
                    style="width:140px">
                    PO Number
                </td>
                <td class="font-monospace fw-bold text-primary">
                    @Model.PurchaseOrderNumber
                </td>
            </tr>
            <tr>
                <td class="text-muted fw-semibold">Supplier</td>
                <td class="fw-semibold">@Model.SupplierName</td>
            </tr>
            <tr>
                <td class="text-muted fw-semibold">Order Date</td>
                <td>@Model.OrderDate.ToString("dd MMM yyyy")</td>
            </tr>
        </table>
    </div>
    <div class="col-md-6">
        <table class="table table-borderless table-sm mb-0">
            <tr>
                <td class="text-muted fw-semibold"
                    style="width:140px">
                    Status
                </td>
                <td>
                    @{
                        var cls = Model.Status switch
                        {
                            POS.Domain.Enums.PurchaseStatus
                                .Pending => "bg-warning text-dark",
                            POS.Domain.Enums.PurchaseStatus
                                .Received => "bg-success",
                            _ => "bg-secondary"
                        };
                    }
                    <span class="badge @cls">@Model.Status</span>
                </td>
            </tr>
            <tr>
                <td class="text-muted fw-semibold">Total Amount</td>
                <td class="fw-bold fs-5 text-primary">
                    $@Model.TotalAmount.ToString("N2")
                </td>
            </tr>
            <tr>
                <td class="text-muted fw-semibold">Notes</td>
                <td class="text-muted">
                    @(Model.Notes ?? "—")
                </td>
            </tr>
        </table>
    </div>
</div>

<hr>

<h6 class="fw-semibold mb-3">
    <i class="bi bi-list-ul me-2"></i>
    Order Items (@Model.Items.Count)
</h6>

<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>#</th>
                <th>Product</th>
                <th class="text-center">Quantity</th>
                <th class="text-end">Unit Cost</th>
                <th class="text-end">Total</th>
            </tr>
        </thead>
        <tbody>
            @{
                int num = 1;
            }
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td class="text-muted">@num</td>
                    <td class="fw-semibold">@item.ProductName</td>
                    <td class="text-center">
                        <span class="badge bg-secondary
                            bg-opacity-10 text-secondary">
                            @item.Quantity
                        </span>
                    </td>
                    <td class="text-end">
                        $@item.UnitCost.ToString("N2")
                    </td>
                    <td class="text-end fw-semibold text-primary">
                        $@item.TotalCost.ToString("N2")
                    </td>
                </tr>
                num++;
            }
        </tbody>
        <tfoot>
            <tr class="table-light">
                <td colspan="4"
                    class="text-end fw-bold">
                    Total
                </td>
                <td class="text-end fw-bold fs-5 text-primary">
                    $@Model.TotalAmount.ToString("N2")
                </td>
            </tr>
        </tfoot>
    </table>
</div>