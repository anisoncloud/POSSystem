@model POS.Application.ViewModels.PosScreenViewModel
@{
    ViewData["Title"] = "Point of Sale";
    Layout = "_PosLayout";
}

<div class="pos-wrapper d-flex" style="height:100vh;overflow:hidden">

    <!-- ═══ LEFT: Product Panel ════════════════════════════════════════════ -->
    <div class="pos-products d-flex flex-column" style="width:60%;border-right:1px solid #dee2e6">

        <!-- Search / Barcode input -->
        <div class="p-3 border-bottom bg-light">
            <div class="input-group input-group-lg">
                <span class="input-group-text"><i class="bi bi-upc-scan"></i></span>
                <input type="text" id="barcodeInput" class="form-control"
                       placeholder="Scan barcode or type product name..."
                       autocomplete="off" autofocus>
                <button class="btn btn-primary" onclick="searchProduct()">
                    <i class="bi bi-search"></i>
                </button>
            </div>
            <!-- Order type selector -->
            <div class="mt-2 d-flex gap-2">
                <div class="btn-group">
                    <input type="radio" class="btn-check" name="orderType" id="retail" value="0" checked>
                    <label class="btn btn-outline-secondary" for="retail">
                        <i class="bi bi-shop"></i> Retail
                    </label>
                    <input type="radio" class="btn-check" name="orderType" id="restaurant" value="1">
                    <label class="btn btn-outline-secondary" for="restaurant">
                        <i class="bi bi-cup-hot"></i> Restaurant
                    </label>
                </div>
                <!-- Table selector (shown for restaurant) -->
                <select id="tableSelect" class="form-select d-none" style="max-width:160px">
                    <option value="">Select Table</option>
                    @foreach (var t in Model.Tables)
                    {
                        <option value="@t.Id">Table @t.TableNumber (@t.Capacity pax)</option>
                    }
                </select>
            </div>
        </div>

        <!-- Category filter pills -->
        <div class="px-3 py-2 d-flex gap-2 flex-wrap border-bottom bg-white" id="categoryFilter">
            <button class="btn btn-sm btn-primary active" onclick="filterCategory(null, this)">All</button>
            @foreach (var cat in Model.Categories)
            {
                <button class="btn btn-sm btn-outline-secondary"
                        onclick="filterCategory(@cat.Id, this)">
                    @cat.Name
                </button>
            }
        </div>
        <!-- Product grid -->
        <div id="productGrid" class="flex-grow-1 overflow-auto p-3">
            <div class="row g-2" id="productCards">
                <!-- Loaded via AJAX -->
            </div>
        </div>
    </div>

    <!-- ═══ RIGHT: Cart Panel ═══════════════════════════════════════════════ -->
    <div class="pos-cart d-flex flex-column" style="width:40%;background:#f8f9fa">

        <div class="px-3 py-2 border-bottom bg-white d-flex align-items-center justify-content-between">
            <h5 class="mb-0"><i class="bi bi-cart3"></i> Cart</h5>
            <button class="btn btn-sm btn-outline-danger" onclick="clearCart()">
                <i class="bi bi-trash"></i> Clear
            </button>
        </div>

        <!-- Cart items -->
        <div id="cartItems" class="flex-grow-1 overflow-auto px-3 py-2">
            <p class="text-muted text-center mt-5" id="emptyCartMsg">
                <i class="bi bi-cart-x" style="font-size:2rem"></i><br>Cart is empty
            </p>
        </div>

        <!-- Summary -->
        <div class="cart-summary p-3 bg-white border-top">
            <div class="d-flex justify-content-between mb-1">
                <span>Subtotal</span><span id="cartSubtotal">৳0.00</span>
            </div>
            <!-- Discount row -->
            <div class="d-flex gap-2 mb-1">
                <select id="discountType" class="form-select form-select-sm" style="max-width:120px"
                        onchange="recalculate()">
                    <option value="0">No discount</option>
                    <option value="1">Fixed ৳</option>
                    <option value="2">Percent %</option>
                </select>
                <input type="number" id="discountValue" class="form-control form-control-sm"
                       placeholder="0" oninput="recalculate()">
                <span class="text-danger small align-self-center" id="discountDisplay">-৳0.00</span>
            </div>
            <div class="d-flex justify-content-between mb-1">
                <span>Tax / VAT</span><span id="cartTax">৳0.00</span>
            </div>
            <div class="d-flex justify-content-between fw-bold fs-5 border-top pt-2">
                <span>Total</span><span id="cartTotal" class="text-success">৳0.00</span>
            </div>

            <!-- Customer info -->
            <div class="mt-2 row g-1">
                <div class="col-6">
                    <input type="text" id="customerName" class="form-control form-control-sm"
                           placeholder="Customer name">
                </div>
                <div class="col-6">
                    <input type="text" id="customerPhone" class="form-control form-control-sm"
                           placeholder="Phone">
                </div>
            </div>

            <!-- Payment methods -->
            <div class="mt-2">
                <label class="form-label small fw-bold">Payment</label>
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-success btn-sm flex-grow-1 payment-btn active"
                            data-method="0" onclick="selectPayment(0,this)">
                        <i class="bi bi-cash"></i> Cash
                    </button>
                    <button class="btn btn-outline-primary btn-sm flex-grow-1 payment-btn"
                            data-method="1" onclick="selectPayment(1,this)">
                        <i class="bi bi-credit-card"></i> Card
                    </button>
                    <button class="btn btn-outline-info btn-sm flex-grow-1 payment-btn"
                            data-method="2" onclick="selectPayment(2,this)">
                        <i class="bi bi-phone"></i> Mobile
                    </button>
                </div>
                <div class="mt-1 input-group input-group-sm" id="paymentRefRow" style="display:none!important">
                    <span class="input-group-text">Ref#</span>
                    <input type="text" id="paymentRef" class="form-control" placeholder="Transaction reference">
                </div>
            </div>

            <!-- Checkout button -->
            <button class="btn btn-success w-100 mt-3 btn-lg fw-bold" onclick="checkout()"
                    id="checkoutBtn" disabled>
                <i class="bi bi-check-circle"></i> Checkout — <span id="checkoutTotal">৳0.00</span>
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/JsBarcode.all.min.js"></script>
    <script src="~/js/PosIndex.js"></script>
}
