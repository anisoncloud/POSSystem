<!-- POS.Web/Views/POS/_ProductGrid.cshtml -->
@model IEnumerable<POS.Application.DTOs.ProductDto>

@if (Model == null || !Model.Any())
{
    <!-- Empty state -->
    <div class="col-12">
        <div class="d-flex flex-column align-items-center
            justify-content-center py-5 text-muted">
            <i class="bi bi-box-seam"
               style="font-size:3rem;opacity:0.3"></i>
            <p class="mt-3 mb-0 fw-semibold">No products found</p>
            <small>Try a different category or search term</small>
        </div>
    </div>
}
else
{
    @foreach (var product in Model)
    {
        <!-- Build the product data as a JSON object -->
        var productJson = System.Text.Json.JsonSerializer.Serialize(
        new
        {
            id = product.Id,
            name = product.Name,
            price = product.SalePrice,
            stock = product.StockQuantity,
            taxRate = product.TaxRate,
            barcode = product.Barcode,
            sku = product.SKU,
            unit = product.UnitType.ToString(),
            imageUrl = product.ImageUrl ?? string.Empty

        });
        var encodedJson = System.Net.WebUtility.HtmlEncode(productJson);
        var isDisabled = !product.IsActive || product.StockQuantity <= 0;
        <div class="col-6 col-sm-4 col-md-3 col-xl-2">
            <div class="product-card @(isDisabled? "product-card-disabled" : "")"
                 data-product="@productJson"
            onclick="handleProductCardClick(this)"
                 title="@product.Name">

                <!-- Product image or placeholder icon -->
                <div class="product-card__image">
                    @if (!string.IsNullOrEmpty(product.ImageUrl))
                    {
                        <img src="@product.ImageUrl"
                             alt="@product.Name"
                             loading="lazy">
                    }
                    else
                    {
                        <div class="product-card__icon">
                            <i class="bi bi-box-seam"></i>
                        </div>
                    }

                    <!-- Out of stock overlay -->
                    @if (product.StockQuantity <= 0)
                    {
                        <div class="product-card__overlay">
                            Out of Stock
                        </div>
                    }

                    <!-- Low stock badge -->
                    @if (product.IsLowStock && product.StockQuantity > 0)
                    {
                        <span class="product-card__low-stock">
                            Low
                        </span>
                    }
                </div>

                <!-- Product info -->
                <div class="product-card__body">
                    <div class="product-card__name"
                         title="@product.Name">
                        @product.Name
                    </div>

                    <div class="product-card__meta">
                        <span class="product-card__sku">
                            @product.SKU
                        </span>
                        <span class="product-card__unit">
                            @product.UnitType
                        </span>
                    </div>

                    <div class="product-card__footer">
                        <span class="product-card__price">
                            $@product.SalePrice.ToString("N2")
                        </span>
                        <span class="product-card__stock
                            @(product.StockQuantity <= 0
                                      ? "product-card__stock--zero"
                                      : product.IsLowStock
                                          ? "product-card__stock--low"
                                          : "product-card__stock--ok")">
                            @product.StockQuantity
                        </span>
                    </div>
                </div>

            </div>
        </div>
    }
}

<!-- Product card styles — scoped to this partial -->
<link rel="stylesheet" href="~/css/PosProductGrid.css" asp-append-version="true" />