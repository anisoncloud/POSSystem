<!-- POS.Web/Views/POS/_ProductGrid.cshtml -->
@model IEnumerable<POS.Application.DTOs.ProductDto>

@if (Model == null || !Model.Any())
{
    <!-- Empty state -->
    <div class="col-12">
        <div class="d-flex flex-column align-items-center
            justify-content-center py-5 text-muted">
            <i class="bi bi-box-seam"
               style="font-size:3rem;opacity:0.3"></i>
            <p class="mt-3 mb-0 fw-semibold">No products found</p>
            <small>Try a different category or search term</small>
        </div>
    </div>
}
else
{
    @foreach (var product in Model)
    {
        <div class="col-6 col-sm-4 col-md-3 col-xl-2">
            <div class="product-card @(!product.IsActive || product.StockQuantity <= 0 ? "product-card--disabled" : "")"
                 onclick="@(product.IsActive && product.StockQuantity > 0
                                                       ? $"addToCartById({product.Id}, '{System.Web.HttpUtility.JavaScriptStringEncode(product.Name)}', {product.SalePrice}, {product.StockQuantity}, {product.TaxRate})"
                                                       : "")"
                 title="@product.Name">

                <!-- Product image or placeholder icon -->
                <div class="product-card__image">
                    @if (!string.IsNullOrEmpty(product.ImageUrl))
                    {
                        <img src="@product.ImageUrl"
                             alt="@product.Name"
                             loading="lazy">
                    }
                    else
                    {
                        <div class="product-card__icon">
                            <i class="bi bi-box-seam"></i>
                        </div>
                    }

                    <!-- Out of stock overlay -->
                    @if (product.StockQuantity <= 0)
                    {
                        <div class="product-card__overlay">
                            Out of Stock
                        </div>
                    }

                    <!-- Low stock badge -->
                    @if (product.IsLowStock && product.StockQuantity > 0)
                    {
                        <span class="product-card__low-stock">
                            Low
                        </span>
                    }
                </div>

                <!-- Product info -->
                <div class="product-card__body">
                    <div class="product-card__name"
                         title="@product.Name">
                        @product.Name
                    </div>

                    <div class="product-card__meta">
                        <span class="product-card__sku">
                            @product.SKU
                        </span>
                        <span class="product-card__unit">
                            @product.UnitType
                        </span>
                    </div>

                    <div class="product-card__footer">
                        <span class="product-card__price">
                            $@product.SalePrice.ToString("N2")
                        </span>
                        <span class="product-card__stock
                            @(product.StockQuantity <= 0
                                    ? "product-card__stock--zero"
                                    : product.IsLowStock
                                        ? "product-card__stock--low"
                                        : "product-card__stock--ok")">
                            @product.StockQuantity
                        </span>
                    </div>
                </div>

            </div>
        </div>
    }
}

<!-- Product card styles — scoped to this partial -->
<style>

    /* ── Product card ───────────────────────────────────────────── */
    .product-card {
        background: #fff;
        border: 1px solid #e9ecef;
        border-radius: 10px;
        overflow: hidden;
        cursor: pointer;
        transition: transform 0.12s, box-shadow 0.12s, border-color 0.12s;
        user-select: none;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .product-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 16px rgba(0,0,0,0.10);
            border-color: #0d6efd;
        }

        .product-card:active {
            transform: scale(0.97);
            box-shadow: none;
        }

    /* Disabled state — out of stock or inactive */
    .product-card--disabled {
        opacity: 0.55;
        cursor: not-allowed;
        filter: grayscale(40%);
    }

        .product-card--disabled:hover {
            transform: none;
            box-shadow: none;
            border-color: #e9ecef;
        }

    /* ── Image area ─────────────────────────────────────────────── */
    .product-card__image {
        position: relative;
        width: 100%;
        padding-top: 70%;
        background: #f8f9fa;
        overflow: hidden;
        flex-shrink: 0;
    }

        .product-card__image img {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    /* Placeholder icon when no image */
    .product-card__icon {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ced4da;
        font-size: 2rem;
    }

    /* Out of stock overlay */
    .product-card__overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.55);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    /* Low stock badge on image */
    .product-card__low-stock {
        position: absolute;
        top: 6px;
        right: 6px;
        background: #dc3545;
        color: #fff;
        font-size: 10px;
        font-weight: 600;
        padding: 2px 6px;
        border-radius: 10px;
        line-height: 1.4;
    }

    /* ── Body ───────────────────────────────────────────────────── */
    .product-card__body {
        padding: 8px 10px;
        display: flex;
        flex-direction: column;
        gap: 4px;
        flex: 1;
    }

    /* Product name — truncate to 2 lines */
    .product-card__name {
        font-size: 13px;
        font-weight: 600;
        color: #212529;
        line-height: 1.3;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 34px;
    }

    /* SKU and unit type row */
    .product-card__meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 4px;
    }

    .product-card__sku {
        font-size: 10px;
        color: #adb5bd;
        font-family: monospace;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        max-width: 70%;
    }

    .product-card__unit {
        font-size: 10px;
        color: #6c757d;
        background: #f0f2f5;
        padding: 1px 5px;
        border-radius: 4px;
        white-space: nowrap;
        flex-shrink: 0;
    }

    /* Price and stock row */
    .product-card__footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: auto;
        padding-top: 4px;
        border-top: 1px solid #f0f2f5;
    }

    .product-card__price {
        font-size: 14px;
        font-weight: 700;
        color: #0d6efd;
    }

    /* Stock quantity badge */
    .product-card__stock {
        font-size: 11px;
        font-weight: 600;
        padding: 1px 7px;
        border-radius: 10px;
    }

    .product-card__stock--ok {
        background: #d1e7dd;
        color: #0a3622;
    }

    .product-card__stock--low {
        background: #fff3cd;
        color: #664d03;
    }

    .product-card__stock--zero {
        background: #f8d7da;
        color: #58151c;
    }

</style>