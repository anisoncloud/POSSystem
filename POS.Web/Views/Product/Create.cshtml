@model POS.Application.DTOs.CreateProductDto
@{
    ViewData["Title"] = "Create Product";
    var categories = ViewBag.Categories as IEnumerable<POS.Application.DTOs.CategoryDto>;
}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="mb-0">Create New Product</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <!-- Name -->
                        <div class="col-12">
                            <label asp-for="Name" class="form-label fw-semibold"></label>
                            <input asp-for="Name" class="form-control"
                                   placeholder="Enter product name">
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <!-- Description -->
                        <div class="col-12">
                            <label asp-for="Description" class="form-label fw-semibold"></label>
                            <textarea asp-for="Description" class="form-control"
                                      rows="3" placeholder="Optional description"></textarea>
                        </div>

                        <!-- Prices -->
                        <div class="col-md-4">
                            <label asp-for="PurchasePrice" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text">@Model.CurrencySymbol</span>
                                <input asp-for="PurchasePrice" class="form-control"
                                       type="number" step="0.01" min="0">
                            </div>
                            <span asp-validation-for="PurchasePrice" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="SalePrice" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text">@Model.CurrencySymbol</span>
                                <input asp-for="SalePrice" class="form-control"
                                       type="number" step="0.01" min="0">
                            </div>
                            <span asp-validation-for="SalePrice" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="TaxRate" class="form-label fw-semibold">
                                Tax Rate (0–1)
                            </label>
                            <input asp-for="TaxRate" class="form-control"
                                   type="number" step="0.01" min="0" max="1"
                                   placeholder="e.g. 0.15">
                            <span asp-validation-for="TaxRate" class="text-danger small"></span>
                        </div>

                        <!-- Stock -->
                        <div class="col-md-6">
                            <label asp-for="InitialStock" class="form-label fw-semibold"></label>
                            <input asp-for="InitialStock" class="form-control"
                                   type="number" min="0">
                            <span asp-validation-for="InitialStock" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="LowStockThreshold" class="form-label fw-semibold"></label>
                            <input asp-for="LowStockThreshold" class="form-control"
                                   type="number" min="0">
                        </div>

                        <!-- Unit type -->
                        <div class="col-md-6">
                            <label asp-for="UnitType" class="form-label fw-semibold"></label>
                            <select asp-for="UnitType" class="form-select"
                                    asp-items="Html.GetEnumSelectList<POS.Domain.Enums.UnitType>()">
                            </select>
                        </div>

                        <!-- Categories (multi-select) -->
                        <!-- ═══ Multi-select category dropdown ═══ -->
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">
                                Categories
                                <span class="text-danger">*</span>
                            </label>
                            @{
                                var options = categories?
                                    .Select(c => new POS.Application.ViewModels.SelectOption
                                    {
                                        Id = c.Id,
                                        Text = c.Name,
                                        SubText = c.ParentCategoryName,
                                    }).ToList() ?? new();

                                var jsonOptions = new System.Text.Json.JsonSerializerOptions
                                {
                                    PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase
                                };
                                // Serialize to JSON string once
                                var optionsJson = System.Text.Json.JsonSerializer
                                                       .Serialize(options, jsonOptions);

                                var selectedJson = System.Text.Json.JsonSerializer
                                                       .Serialize(Model.CategoryIds);
                            }

                            <div class="multi-select-wrapper "
                                 id="categoryMultiSelect"
                                 data-field-name="CategoryIds"
                                 data-placeholder="Click to select categories..."
                                 data-options='@Html.Raw(optionsJson)'
                                 data-selected='@Html.Raw(selectedJson)'>
                            </div>

                            @if (ViewData.ModelState["CategoryIds"]?
                                    .Errors.Count > 0)
                            {
                                <div class="text-danger small mt-1">
                                    @ViewData.ModelState["CategoryIds"]!
                                    .Errors[0].ErrorMessage
                                </div>
                            }
                        </div>

                        <!-- Image -->
                        <div class="col-12">
                            <label class="form-label fw-semibold">Product Image</label>
                            <input type="file" name="imageFile"
                                   class="form-control" accept="image/*">
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary px-4">
                            Create Product
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/multi-select.js"></script>
    <script>
        // Initialize all multi-select wrappers on the page
        document.querySelectorAll('.multi-select-wrapper')
            .forEach(el => initMultiSelect(el));
    </script>
}
