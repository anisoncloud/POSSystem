<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Point of Sale System">

    <title>@ViewData["Title"] — POS System</title>
    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <!-- Multi-select CSS -->
    <link rel="stylesheet" href="~/css/multi-select.css">
    <link rel="stylesheet" href="~/css/PosStyleSheet.css">
    <!-- POS specific styles -->

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>

    <!-- ═══════════════════════════════════════════════════════════════
         TOP NAVBAR
    ═══════════════════════════════════════════════════════════════════ -->
    <nav class="pos-navbar">

        <!-- Brand -->
        <a href="/" class="pos-navbar-brand">
            <div class="brand-icon">
                <i class="bi bi-bag-check-fill"></i>
            </div>
            <span>POS System</span>
        </a>

        <!-- Center navigation links -->
        <div class="pos-navbar-center">

            <a asp-controller="POS"
               asp-action="Index"
               class="pos-nav-btn
                @(ViewContext.RouteData.Values["controller"]
                   ?.ToString() == "POS" ? "active" : "")">
                <i class="bi bi-cart3"></i>
                <span>POS</span>
            </a>

            <a asp-controller="Order"
               asp-action="Index"
               class="pos-nav-btn
                @(ViewContext.RouteData.Values["controller"]
                   ?.ToString() == "Order" ? "active" : "")">
                <i class="bi bi-receipt"></i>
                <span>Orders</span>
            </a>

            @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
            {
                <a asp-controller="Product"
                   asp-action="Index"
                   class="pos-nav-btn
                    @(ViewContext.RouteData.Values["controller"]
                       ?.ToString() == "Product" ? "active" : "")">
                    <i class="bi bi-box-seam"></i>
                    <span>Products</span>
                </a>

                <a asp-controller="Inventory"
                   asp-action="Index"
                   class="pos-nav-btn
                    @(ViewContext.RouteData.Values["controller"]
                       ?.ToString() == "Inventory" ? "active" : "")">
                    <i class="bi bi-archive"></i>
                    <span>Inventory</span>
                </a>

                <a asp-controller="Table"
                   asp-action="Index"
                   class="pos-nav-btn
                    @(ViewContext.RouteData.Values["controller"]
                       ?.ToString() == "Table" ? "active" : "")">
                    <i class="bi bi-grid-3x3-gap"></i>
                    <span>Tables</span>
                </a>

                <a asp-controller="Report"
                   asp-action="Index"
                   class="pos-nav-btn
                    @(ViewContext.RouteData.Values["controller"]
                       ?.ToString() == "Report" ? "active" : "")">
                    <i class="bi bi-bar-chart-line"></i>
                    <span>Reports</span>
                </a>
            }

            @if (User.IsInRole("Admin"))
            {
                <div class="pos-nav-divider"></div>

                <a asp-controller="Category"
                   asp-action="Index"
                   class="pos-nav-btn
                    @(ViewContext.RouteData.Values["controller"]
                       ?.ToString() == "Category" ? "active" : "")">
                    <i class="bi bi-tags"></i>
                    <span>Categories</span>
                </a>

                <a asp-controller="Branch"
                   asp-action="Index"
                   class="pos-nav-btn
                    @(ViewContext.RouteData.Values["controller"]
                       ?.ToString() == "Branch" ? "active" : "")">
                    <i class="bi bi-building"></i>
                    <span>Branches</span>
                </a>
            }

            @if (User.IsInRole("Kitchen"))
            {
                <a asp-controller="Kitchen"
                   asp-action="Display"
                   class="pos-nav-btn
                    @(ViewContext.RouteData.Values["controller"]
                       ?.ToString() == "Kitchen" ? "active" : "")">
                    <i class="bi bi-fire"></i>
                    <span>Kitchen</span>
                </a>
            }

        </div>

        <!-- Right side — clock, branch, user, logout -->
        <div class="pos-navbar-right">

            <!-- Live clock -->
            <div class="pos-clock" id="posClock">--:--:--</div>

            <div class="pos-nav-divider"></div>

            <!-- Branch name -->
            <div class="pos-branch-badge">
                <i class="bi bi-building" style="font-size:12px"></i>
                <span>
                    @(User.FindFirst("BranchName")?.Value
                      ?? "Main Branch")
                </span>
            </div>

            <div class="pos-nav-divider"></div>

            <!-- Logged-in user -->
            <div class="pos-user-badge">
                <div class="pos-user-avatar">
                    @{
                        var fullName = User.FindFirst("FullName")?.Value
                                    ?? User.Identity?.Name
                                    ?? "U";
                        var initials = string.Concat(
                            fullName.Split(' ')
                                    .Take(2)
                                    .Select(w => w.Length > 0
                                        ? w[0].ToString().ToUpper()
                                        : ""));
                    }
                    @initials
                </div>
                <span class="pos-user-name">@fullName</span>
                <span class="text-muted"
                      style="font-size:11px">
                    (@User.FindFirst(
                                            System.Security.Claims.ClaimTypes.Role)
                    ?.Value)
                </span>
            </div>

            <div class="pos-nav-divider"></div>

            <!-- Logout -->
            <form asp-controller="Account"
                  asp-action="Logout"
                  method="post"
                  class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="pos-logout-btn">
                    <i class="bi bi-box-arrow-right"
                       style="font-size:13px"></i>
                    <span>Logout</span>
                </button>
            </form>

        </div>
    </nav>

    <!-- ═══════════════════════════════════════════════════════════════
         MAIN BODY
    ═══════════════════════════════════════════════════════════════════ -->
    <div class="pos-body">

        <!-- Alert bar — TempData success/error messages -->
        <div class="pos-alert-bar">
            @if (TempData["success"] != null)
            {
                <div class="alert alert-success alert-dismissible
                    fade show mb-0" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    @TempData["success"]
                    <button type="button"
                            class="btn-close btn-close-sm"
                            data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["error"] != null)
            {
                <div class="alert alert-danger alert-dismissible
                    fade show mb-0" role="alert">
                    <i class="bi bi-x-circle-fill me-2"></i>
                    @TempData["error"]
                    <button type="button"
                            class="btn-close btn-close-sm"
                            data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["warning"] != null)
            {
                <div class="alert alert-warning alert-dismissible
                    fade show mb-0" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @TempData["warning"]
                    <button type="button"
                            class="btn-close btn-close-sm"
                            data-bs-dismiss="alert"></button>
                </div>
            }
        </div>

        <!-- Page content rendered here -->
        <div class="pos-content">
            @RenderBody()
        </div>

    </div>

    <!-- ═══════════════════════════════════════════════════════════════
         SCRIPTS
    ═══════════════════════════════════════════════════════════════════ -->
    <!-- Bootstrap bundle (includes Popper) -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js">
    </script>

    <!-- SignalR for Kitchen display -->
    <script src="~/lib/signalr/dist/browser/signalr.min.js"></script>

    <!-- JsBarcode for barcode rendering -->
    <script src="~/lib/jsbarcode/JsBarcode.all.min.js"></script>

    <!-- Live clock -->
    <script>
        (function () {
        const clockEl = document.getElementById('posClock');
        if (!clockEl) return;

        function updateClock() {
        const now  = new Date();
        const h    = String(now.getHours()).padStart(2, '0');
        const m    = String(now.getMinutes()).padStart(2, '0');
        const s    = String(now.getSeconds()).padStart(2, '0');
        const day  = now.toLocaleDateString('en-US', {
        weekday: 'short',
        month:   'short',
        day:     'numeric'
        });
        clockEl.textContent = `${day}  ${h}:${m}:${s}`;
        }

        updateClock();
        setInterval(updateClock, 1000);
        })();
    </script>

    <!-- Auto-dismiss alerts after 4 seconds -->
    <script>
        (function () {
        document.querySelectorAll('.pos-alert-bar .alert')
        .forEach(alert => {
        setTimeout(() => {
        const bsAlert =
        bootstrap.Alert.getOrCreateInstance(alert);
        bsAlert.close();
        }, 4000);
        });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>