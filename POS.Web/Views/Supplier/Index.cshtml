@model IEnumerable<POS.Application.DTOs.SupplierDto>
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Supplier</h4>
    <a asp-action="Create" class="btn btn-primary">+ Add Supplier</a>
</div>

<div class="row g-3">
    @foreach (var supplier in Model)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm
                ">
                <div class="card-header d-flex
                    justify-content-between align-items-center">
                    <h6 class="mb-0 fw-semibold">@supplier.Name</h6>
                    
                </div>
                <div class="card-body">
                    <div class="mb-2">
                        <small class="text-muted">Address</small>
                        <div>@supplier.Address</div>
                    </div>
                    <div class="mb-2">
                        <small class="text-muted">Phone</small>
                        <div>@supplier.Phone</div>
                    </div>
                    <div class="mb-2">
                        <small class="text-muted">Created</small>
                        <div>@supplier.ContactPerson</div>
                    </div>
                </div>
                <div class="card-footer d-flex gap-2 flex-wrap">
                    <a asp-action="Details"
                       asp-route-id="@supplier.Id"
                       class="btn btn-sm btn-outline-info">Details</a>

                    <a asp-action="Edit"
                       asp-route-id="@supplier.Id"
                       class="btn btn-sm btn-outline-primary">Edit</a>

                    

                    <!-- Delete -->
                    <form asp-action="Delete"
                          asp-route-id="@supplier.Id"
                          method="post" class="d-inline"
                          onsubmit="return confirm(
                        'Delete branch @supplier.Name? This cannot be undone.')">
                        @Html.AntiForgeryToken()
                        <button type="submit"
                                class="btn btn-sm btn-outline-danger">
                            Delete
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>